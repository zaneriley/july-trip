# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Google Maps API key for the planning map. Enable the "Maps JavaScript API" on
# it (we plot our own pins and routes; we don't use Directions/Places — Google
# can't route transit in Japan, so per-pin train directions deep-link to the
# Google Maps app instead). The key ships in the client bundle by design, so the
# real protection is a HTTP-referrer restriction in the Google Cloud console:
# limit it to *.pages.dev and localhost. Left blank, the map shows a note.
# In CI this comes from the GOOGLE_MAPS_API_KEY repo secret (see deploy.yml).
PUBLIC_GOOGLE_MAPS_API_KEY=

# Base URL of the deployed hearts Worker, e.g.
#   https://july-trip-hearts.<your-account>.workers.dev
# Left blank, hearts work locally per device but counts are not shared.
PUBLIC_HEART_API_URL=
