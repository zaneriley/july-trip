# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Google Maps API key. Used only for the inline place maps, via the Maps Embed
# API — so enable "Maps Embed API" on the key (Directions/Places aren't used:
# Google's developer APIs don't do transit routing in Japan, so the route and
# coffee links deep-link to the Google Maps app instead, and need no key).
# The key ships in the client bundle by design, so the real protection is a
# HTTP-referrer restriction in the Google Cloud console: limit it to *.pages.dev
# and localhost. Left blank, the inline maps show a note and the deep-links still
# work. In CI this comes from the GOOGLE_MAPS_API_KEY repo secret (see deploy.yml).
PUBLIC_GOOGLE_MAPS_API_KEY=

# Base URL of the deployed hearts Worker, e.g.
#   https://july-trip-hearts.<your-account>.workers.dev
# Left blank, hearts work locally per device but counts are not shared.
PUBLIC_HEART_API_URL=
