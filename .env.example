# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Google Maps JavaScript API key. This ships in the client bundle by design, so
# the real protection is a HTTP-referrer restriction in the Google Cloud console:
# limit it to *.pages.dev and localhost. Enable "Maps JavaScript API" and
# "Places API". Left blank, maps render a "needs API key" note instead.
# In CI this comes from the GOOGLE_MAPS_API_KEY repo secret (see deploy.yml).
PUBLIC_GOOGLE_MAPS_API_KEY=

# Base URL of the deployed hearts Worker, e.g.
#   https://july-trip-hearts.<your-account>.workers.dev
# Left blank, hearts work locally per device but counts are not shared.
PUBLIC_HEART_API_URL=
