---
import Base from '../layouts/Base.astro';
import { comparisonColumns } from '../lib/compare';
import { getCollection } from 'astro:content';

// How we landed on Numazu — the original three-city comparison, kept as the
// decision archaeology now that the city is settled. The live decision (which
// lodging) is the home; this is the "how we got here" backstory, one click away.
const columns = await comparisonColumns();
type Col = (typeof columns)[number];

const weather = await getCollection('weather');
const wByDest = new Map(weather.map((w) => [w.data.destination.id, w.data]));

const stayByDest: Record<string, string> = {
  numazu: 'Three stays, about ¥19–29k/person — an onsen hotel with a free Mishima shuttle, the suspended-sphere INN THE PARK, or onsen domes; reservable private baths.',
  atami: 'Four stays, about ¥21–39k/person — family resorts and buffet hotels, most a short shuttle or taxi from the station.',
  kurobe: 'Four ryokan in Unazuki, about ¥24–85k/person with two meals — private family baths are common, a 2–5 min walk from the station.',
};

const rows: { label: string; val: (c: Col) => string }[] = [
  { label: 'getting there', val: (c) => c.time ?? '—' },
  { label: 'cost per adult', val: (c) => c.cost ?? '—' },
  { label: 'weather', val: (c) => wByDest.get(c.dest.id)?.headline ?? '—' },
  { label: 'where to stay', val: (c) => stayByDest[c.dest.id] ?? '—' },
  { label: 'with a three-year-old', val: (c) => c.dest.data.kidNote },
  { label: 'food', val: (c) => c.dest.data.foodNote },
];

const gridCols = `6.5rem repeat(${columns.length}, 13rem)`;
const labelCell = 'sticky left-0 z-10 bg-white border-r border-stone-100';
---

<Base
  title="How we chose: Numazu, Atami or Kurobe? — July 3 to 5"
  description="The original three-way comparison behind the trip — Mishima & Numazu's food, easy seaside Atami, or the alpine route at Kurobe. We landed on Numazu."
  ogImage="/og/home.png"
  wide={true}
>
  <header class="mb-6">
    <a href="/" class="text-sm text-stone-500 hover:text-stone-800">← where we're staying</a>
    <h1 class="mt-2 text-2xl font-semibold text-stone-900">How we chose Numazu</h1>
    <p class="mt-2 text-[15px] leading-relaxed text-stone-600">
      We weighed three options for the long weekend, the same questions for each.
      <span class="text-stone-800">Numazu won</span> — closest, strongest food, and the most rain-proof for a toddler.
      Here's the comparison we settled it from.
    </p>
  </header>

  <div class="overflow-x-auto rounded-2xl border border-stone-200 bg-white">
    <div class="grid w-max" style={`grid-template-columns: ${gridCols}`}>
      <div class={labelCell}></div>
      {
        columns.map((c) => (
          <a href={`/${c.dest.id}`} class="block border-l border-stone-100 transition hover:bg-stone-50">
            <img src={c.dest.data.heroImage} alt={c.dest.data.name} class="aspect-[16/9] w-full object-cover" />
            <div class="px-3 py-2.5">
              <h2 class="m-0 text-[17px] font-semibold text-stone-900">{c.dest.data.name}</h2>
              <p class="m-0 mt-0.5 text-[12px] leading-snug text-stone-500">{c.dest.data.tagline}</p>
            </div>
          </a>
        ))
      }

      {
        rows.map((row) => (
          <>
            <div class={`${labelCell} border-t px-3 py-3 text-xs text-stone-400`}>{row.label}</div>
            {columns.map((c) => (
              <div class="border-l border-t border-stone-100 px-3 py-3 text-[14px] leading-snug text-stone-800">
                {row.val(c)}
              </div>
            ))}
          </>
        ))
      }

      <div class={`${labelCell} border-t`}></div>
      {
        columns.map((c) => (
          <a
            href={`/${c.dest.id}`}
            class="border-l border-t border-stone-100 px-3 py-3 text-center text-[14px] font-medium text-stone-800 transition hover:bg-stone-50"
          >
            Look closer →
          </a>
        ))
      }
    </div>
  </div>

  <p class="mt-6 text-center text-[13px] text-stone-400">
    <a href="/" class="underline decoration-stone-300 underline-offset-2 hover:text-stone-700">
      ← back to where we're staying
    </a>
  </p>
</Base>
