---
import Base from '../layouts/Base.astro';
import { comparisonColumns } from '../lib/compare';

// Home is the decision: Kurobe vs Atami, side by side. The actual deciding happens
// in the group thread — this page is the shared evidence everyone links to. Each
// destination's own page (the map + the places) is one tap away.
const columns = await comparisonColumns();

// The qualitative rows, in the order they help the decision.
const rows = [
  { label: 'the pace', key: 'pace' as const },
  { label: 'with a three-year-old', key: 'withChild' as const },
  { label: 'early July', key: 'weather' as const },
];
---

<Base
  title="Kurobe or Atami? — July 3 to 5"
  description="Two options for the long weekend, side by side: the alpine route at Kurobe, or onsen by the sea at Atami. Have a look, then we'll sort it out in the chat."
  ogImage="/og/home.png"
>
  <header class="mb-6">
    <h1 class="m-0 text-2xl font-semibold text-stone-900">Where should we go, July 3 to 5?</h1>
    <p class="mt-2 text-[15px] leading-relaxed text-stone-600">
      Two options, side by side. Have a look at both — then we'll sort it out in the chat.
    </p>
  </header>

  <!-- The two options as a side-by-side, each tapping through to its own map. -->
  <div class="grid grid-cols-2 gap-3">
    {
      columns.map(({ dest, time, cost }) => (
        <a
          href={`/${dest.id}`}
          class="group flex flex-col overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm transition hover:border-stone-400"
        >
          <img
            src={dest.data.heroImage}
            alt={dest.data.name}
            class="aspect-[4/3] w-full object-cover"
          />
          <div class="flex flex-1 flex-col px-3 py-3">
            <h2 class="m-0 text-lg font-semibold text-stone-900">{dest.data.name}</h2>
            <p class="mt-1 text-[13px] leading-snug text-stone-500">{dest.data.tagline}</p>
            <dl class="mt-3 space-y-1.5 text-[13px]">
              <div>
                <dt class="text-stone-400">getting there</dt>
                <dd class="m-0 text-stone-800">{time ?? '—'}</dd>
              </div>
              <div>
                <dt class="text-stone-400">cost per adult</dt>
                <dd class="m-0 text-stone-800">{cost ?? '—'}</dd>
              </div>
            </dl>
            <span class="mt-3 text-sm text-stone-500 group-hover:text-stone-800">
              see the map and places →
            </span>
          </div>
        </a>
      ))
    }
  </div>

  <!-- The softer, side-by-side comparison for the things numbers don't capture. -->
  <div class="mt-6 overflow-hidden rounded-2xl border border-stone-200 bg-white">
    {
      rows.map((row, i) => (
        <div class={`grid grid-cols-2 gap-4 px-4 py-3 ${i > 0 ? 'border-t border-stone-100' : ''}`}>
          {columns.map(({ dest }) => (
            <div>
              <p class="m-0 text-xs text-stone-400">{row.label}</p>
              <p class="mt-0.5 text-[14px] leading-snug text-stone-700">{dest.data[row.key]}</p>
            </div>
          ))}
        </div>
      ))
    }
  </div>
</Base>
