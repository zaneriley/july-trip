---
import Base from '../layouts/Base.astro';
import { comparisonColumns } from '../lib/compare';
import { getCollection } from 'astro:content';

// Home is one aligned comparison: two photo-headed columns and the same set of
// rows for both, so you read straight across — Kurobe's time vs Atami's time,
// Kurobe's weather vs Atami's — and decide. Depth lives behind each "look closer".
const columns = await comparisonColumns();
type Col = (typeof columns)[number];

const weather = await getCollection('weather');
const wByDest = new Map(weather.map((w) => [w.data.destination.id, w.data]));

// Two more signature shots per city under the hero, so the columns convey the
// character at a glance — Kurobe's gorge-and-onsen, Atami's easy seaside.
const signatures: Record<string, string[]> = {
  kurobe: ['/photos/kurobe-gorge-train.jpg', '/photos/unazuki-street.jpg'],
  atami: ['/photos/moon-terrace.jpg', '/photos/sun-beach-day.jpg'],
};

// A one-line lodging summary per city for the comparison row (detail lives in the
// "where to stay" section on each city page).
const stayByDest: Record<string, string> = {
  kurobe: 'Four ryokan in Unazuki, about ¥24–85k/person with two meals — private family baths are common, a 2–5 min walk from the station.',
  atami: 'Four stays, about ¥21–39k/person — family resorts and buffet hotels, most a short shuttle or taxi from the station.',
};

// The deciding dimensions, in the order a toddler weekend weighs them. Every row
// resolves to a value for both cities, so the comparison never goes lopsided.
const rows: { label: string; val: (c: Col) => string }[] = [
  { label: 'getting there', val: (c) => c.time ?? '—' },
  { label: 'cost per adult', val: (c) => c.cost ?? '—' },
  { label: 'weather', val: (c) => wByDest.get(c.dest.id)?.headline ?? '—' },
  { label: 'where to stay', val: (c) => stayByDest[c.dest.id] ?? '—' },
  { label: 'with a three-year-old', val: (c) => c.dest.data.kidNote },
  { label: 'food', val: (c) => c.dest.data.foodNote },
];
---

<Base
  title="Kurobe or Atami? — July 3 to 5"
  description="Two options for the long weekend, compared row by row: the alpine route at Kurobe, or onsen by the sea at Atami. Pick one — we'll settle it in the chat."
  ogImage="/og/home.png"
  wide={false}
>
  <header class="mb-6">
    <h1 class="m-0 text-2xl font-semibold text-stone-900">Where should we go, July 3 to 5?</h1>
    <p class="mt-2 text-[15px] leading-relaxed text-stone-600">
      The long weekend is <span class="text-stone-800">Friday to Sunday</span>. Two options, the same
      questions for each — read across, then we'll settle it in the chat.
    </p>
  </header>

  <div class="overflow-hidden rounded-2xl border border-stone-200 bg-white">
    {/* Two photo-headed columns. */}
    <div class="grid grid-cols-2">
      {
        columns.map((c, i) => (
          <a href={`/${c.dest.id}`} class={`block ${i === 0 ? 'border-r border-stone-100' : ''}`}>
            <img src={c.dest.data.heroImage} alt={c.dest.data.name} class="aspect-[16/9] w-full object-cover" />
            <div class="grid grid-cols-2 gap-px bg-stone-100">
              {(signatures[c.dest.id] ?? []).map((s) => (
                <img src={s} alt="" loading="lazy" class="aspect-[4/3] w-full object-cover" />
              ))}
            </div>
            <div class="px-3 py-2.5">
              <h2 class="m-0 text-lg font-semibold text-stone-900">{c.dest.data.name}</h2>
              <p class="m-0 mt-0.5 text-[13px] leading-snug text-stone-500">{c.dest.data.tagline}</p>
            </div>
          </a>
        ))
      }
    </div>

    {/* The same row for both cities — the value columns sit under the photo columns. */}
    {
      rows.map((row) => (
        <div class="border-t border-stone-100 px-4 py-3">
          <p class="m-0 text-xs text-stone-400">{row.label}</p>
          <div class="mt-1 grid grid-cols-2 gap-4">
            {columns.map((c) => (
              <p class="m-0 text-[14px] leading-snug text-stone-800">{row.val(c)}</p>
            ))}
          </div>
        </div>
      ))
    }

    {/* Into the depth, once you're leaning. */}
    <div class="grid grid-cols-2 gap-px border-t border-stone-100 bg-stone-100">
      {
        columns.map((c) => (
          <a
            href={`/${c.dest.id}`}
            class="bg-white px-4 py-3 text-center text-[15px] font-medium text-stone-800 transition hover:bg-stone-50"
          >
            Look closer at {c.dest.data.name} →
          </a>
        ))
      }
    </div>
  </div>
</Base>
