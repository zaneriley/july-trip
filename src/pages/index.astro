---
import Base from '../layouts/Base.astro';
import StayMap from '../components/StayMap.astro';
import { getCollection } from 'astro:content';

// The home is a decision AID for the group: where the three places are (a map),
// what they cost, how long they take, how guests rate them, and what they're
// like. No urgency sell and no "my pick" on the page — that nudge is a message
// Z sends in iMessage; this page just helps everyone weigh it.
const picks = (await getCollection('picks')).sort((a, b) => a.data.order - b.data.order);
const live = picks.filter((p) => p.data.role !== 'passed');
const passed = picks.filter((p) => p.data.role === 'passed');

const photos = await getCollection('photos');
const photosBySubject = new Map<string, (typeof photos)[number][]>();
for (const ph of photos) {
  const list = photosBySubject.get(ph.data.subject) ?? [];
  list.push(ph);
  photosBySubject.set(ph.data.subject, list);
}

// A neutral one-word type per place (not a ranking) so the chips read as "what
// kind of place is this", paired with the map pin number.
const kindById: Record<string, string> = {
  'pick-shuzenji': 'private cabin',
  'innthepark': 'forest cottage',
  'also-sunvalley': 'onsen hotel',
};

const factRows: { key: 'onsen' | 'fits' | 'getThere' | 'meals' | 'toddler'; label: string }[] = [
  { key: 'fits', label: 'all in one place' },
  { key: 'onsen', label: 'onsen' },
  { key: 'getThere', label: 'getting there' },
  { key: 'meals', label: 'meals' },
  { key: 'toddler', label: 'with the toddler' },
];

// Stays with coordinates, for the map (numbered to match the cards).
const mapStays = live
  .filter((p) => typeof p.data.lat === 'number' && typeof p.data.lng === 'number')
  .map((p) => ({ id: p.id, name: p.data.name, lat: p.data.lat!, lng: p.data.lng!, fromBase: p.data.getThere ?? '', n: p.data.order }));

const srcLink = 'text-stone-400 underline decoration-stone-300 underline-offset-2 hover:text-stone-700';

// The nudge to decide goes out as an iMessage, not page copy.
const shareMsg = "Where we might stay for the July trip — Numazu, Jul 3–5. Have a look and tell me which one you like: https://july-trip.pages.dev";
const smsHref = `sms:&body=${encodeURIComponent(shareMsg)}`;
---

<Base
  title="Where we might stay — Numazu, July 3 to 5"
  description="Three places near Mishima for the five of us, July 3–5: where each one is, what it costs, how long it takes, and how guests rate it. Have a look and tell me which."
  ogImage="/og/home.png"
>
  <header class="mb-5">
    <h1 class="m-0 text-2xl font-semibold text-stone-900">Where we might stay</h1>
    <p class="mt-2 text-[15px] leading-relaxed text-stone-600">
      Three places near <span class="text-stone-800">Mishima / Numazu</span> for the five of us,
      <span class="text-stone-800">Fri–Sun July 3–5</span>. Here's where each one is, what it costs, how long
      it takes, and how guests rate it — have a look and tell me which you like.
    </p>
  </header>

  {/* Where they are — the thing place-names alone can't convey. */}
  <section class="mb-2">
    <h2 class="mb-2 text-[13px] font-medium uppercase tracking-wide text-stone-400">Where they are</h2>
    <StayMap stays={mapStays} />
    <p class="mt-2 text-[12px] text-stone-400">Numbered to match the cards below; the red pin is Mishima station, our base. Tap a pin.</p>
  </section>

  <div class="mt-5 space-y-5">
    {
      live.map((p) => {
        const d = p.data;
        const imgs = d.photoSubject ? photosBySubject.get(d.photoSubject) ?? [] : [];
        return (
          <div id={p.id} class="scroll-mt-4 overflow-hidden rounded-2xl border border-stone-200 bg-white">
            {imgs.length > 0 && (
              <div class="relative">
                <div class="flex snap-x snap-mandatory gap-1 overflow-x-auto [-webkit-overflow-scrolling:touch] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
                  {imgs.map((ph) => (
                    <img
                      src={ph.data.src}
                      alt={ph.data.alt}
                      loading="lazy"
                      class={`aspect-[16/9] ${imgs.length > 1 ? 'w-[92%]' : 'w-full'} shrink-0 snap-start object-cover`}
                    />
                  ))}
                </div>
                <span class="absolute left-3 top-3 inline-flex h-7 w-7 items-center justify-center rounded-full bg-emerald-600 text-[13px] font-semibold text-white">{d.order}</span>
                {imgs.length > 1 && (
                  <span class="pointer-events-none absolute right-3 top-3 rounded-full bg-black/55 px-2 py-0.5 text-[11px] font-medium text-white">{imgs.length} photos · swipe</span>
                )}
              </div>
            )}

            <div class="px-4 py-4">
              <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                <h2 class="m-0 text-[19px] font-semibold text-stone-900">{d.name}</h2>
                {kindById[p.id] && <span class="rounded-full bg-stone-100 px-2 py-0.5 text-[12px] text-stone-500">{kindById[p.id]}</span>}
              </div>

              {/* Rating — honest: a star + count where guests have rated it, a plain note where they haven't. */}
              {d.rating ? (
                <p class="m-0 mt-1.5 text-[13px] text-stone-600">
                  <span class="font-semibold text-amber-600">★ {d.rating}</span>
                  <span class="text-stone-400"> / 5 · {d.ratingCount} reviews · {d.ratingSource}</span>
                </p>
              ) : d.ratingNote ? (
                <p class="m-0 mt-1.5 text-[13px] text-stone-400">{d.ratingNote}</p>
              ) : null}

              {d.vibe && <p class="m-0 mt-2 text-[14px] leading-snug text-stone-600">{d.vibe}</p>}

              {d.allIn && (
                <p class="m-0 mt-3 rounded-lg bg-stone-50 px-3 py-2 text-[14px] font-medium text-stone-900">{d.allIn}</p>
              )}

              <dl class="m-0 mt-3 grid grid-cols-[6.5rem_1fr] gap-x-3 gap-y-2 text-[13px] leading-snug">
                {factRows.map((r) =>
                  d[r.key] ? (
                    <>
                      <dt class="text-stone-400">{r.label}</dt>
                      <dd class="m-0 text-stone-700">{d[r.key]}</dd>
                    </>
                  ) : null,
                )}
                {d.availSat && (
                  <>
                    <dt class="text-stone-400">Sat Jul 4</dt>
                    <dd class="m-0 text-stone-700">{d.availSat} (checked Jun 29)</dd>
                  </>
                )}
              </dl>

              {d.catch && (
                <p class="m-0 mt-3 text-[13px] leading-snug text-stone-500">
                  <span class="font-medium text-stone-700">the catch:</span> {d.catch}
                </p>
              )}
              {d.backup && <p class="m-0 mt-1 text-[13px] leading-snug text-stone-500">{d.backup}</p>}

              <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
                {d.bookUrl && (
                  <a
                    href={d.bookUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="rounded-full bg-stone-900 px-4 py-2 text-[13px] font-semibold text-white transition hover:bg-stone-700"
                  >
                    Book on Jalan →
                  </a>
                )}
                {d.mapUrl && (
                  <a href={d.mapUrl} target="_blank" rel="noopener noreferrer" class="text-[13px] font-medium text-stone-600 hover:text-stone-900">
                    📍 Google Maps
                  </a>
                )}
                {d.detailUrl && (
                  <a href={d.detailUrl} class="text-[13px] font-medium text-stone-500 hover:text-stone-800">more detail →</a>
                )}
              </div>
            </div>
          </div>
        );
      })
    }
  </div>

  {/* Passed-on, collapsed — named honestly so the curation reads as trustworthy. */}
  <details class="mt-6 rounded-xl border border-stone-200 bg-white px-4 py-3">
    <summary class="cursor-pointer text-[14px] font-medium text-stone-700">Four we passed on (and why)</summary>
    <ul class="m-0 mt-3 list-none space-y-2.5 p-0">
      {
        passed.map((p) => (
          <li class="text-[13px] leading-snug text-stone-600">
            <span class="font-semibold text-stone-800">{p.data.name}.</span> {p.data.why}
          </li>
        ))
      }
    </ul>
  </details>

  {/* The decision nudge lives in iMessage, not in page copy. */}
  <div class="mt-6 rounded-xl border border-stone-200 bg-stone-50 px-4 py-4 text-center">
    <p class="m-0 text-[14px] text-stone-600">Seen enough? Send it round and let's pick one.</p>
    <a
      href={smsHref}
      class="mt-3 inline-block rounded-full bg-emerald-600 px-5 py-2.5 text-[14px] font-semibold text-white transition hover:bg-emerald-700"
    >
      Share with the group (iMessage)
    </a>
  </div>

  <p class="mt-5 text-[13px] leading-relaxed text-stone-500">
    Want the wider net? Here's
    <a href="/glamping" class={srcLink}> every place I looked at</a>, and
    <a href="/cities" class={srcLink}> how we landed on Numazu</a>.
  </p>
</Base>
