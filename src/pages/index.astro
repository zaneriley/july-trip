---
import Base from '../layouts/Base.astro';
import DestinationTab from '../components/DestinationTab.astro';
import Card from '../components/Card.astro';
import Journeys from '../components/Journeys.astro';
import DestinationMap from '../components/DestinationMap.astro';
import { getCollection, getEntries, render } from 'astro:content';

// The whole page is built from the content graph (see src/content.config.ts).
// Nothing here is hardcoded trip prose — destinations, the places inside them,
// and the journeys to each place all come from src/data, every figure carrying
// its source. To add or correct anything, edit the data, not this file.
const destinations = (await getCollection('destinations')).sort(
  (a, b) => a.data.order - b.data.order,
);
const allPlaces = await getCollection('places');
const allJourneys = await getCollection('journeys');
const allPois = await getCollection('pois');
const allPaths = await getCollection('paths');

// Resolve everything once, here, so the markup below stays flat and readable.
const view = await Promise.all(
  destinations.map(async (dest) => {
    const places = await Promise.all(
      allPlaces
        .filter((place) => place.data.destination.id === dest.id)
        .map(async (place) => {
          const { Content: PlaceBody } = await render(place);
          return {
            place,
            PlaceBody,
            placeSources: await getEntries(place.data.sources),
            journeys: allJourneys.filter((j) => j.data.to.id === place.id),
          };
        }),
    );
    return {
      dest,
      places,
      pois: allPois.filter((poi) => poi.data.destination.id === dest.id),
      paths: allPaths.filter((path) => path.data.destination.id === dest.id),
    };
  }),
);
---

<Base title="July 3–5 — Kurobe or Atami?">
  <header class="mb-6">
    <h1 class="m-0 text-2xl font-semibold text-stone-900">Where should we go, July 3 to 5?</h1>
  </header>

  <!--
    Tabs. Sentence-case labels, no all-caps, no pill styling — just buttons that
    swap which destination panel is visible.
  -->
  <div role="tablist" aria-label="Destinations" class="mb-6 flex gap-2">
    {
      view.map(({ dest }, i) => (
        <button
          type="button"
          role="tab"
          data-tab={dest.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`panel-${dest.id}`}
          class="rounded-full border border-stone-300 px-4 py-2 text-[15px] text-stone-600 transition aria-selected:border-stone-900 aria-selected:bg-stone-900 aria-selected:text-white"
        >
          {dest.data.name}
        </button>
      ))
    }
  </div>

  {
    view.map(({ dest, places, pois, paths }, i) => (
      <DestinationTab id={dest.id} label={dest.data.name} active={i === 0}>
        {/*
          Two panes on desktop: the planning map on the left (it stays put as you
          scroll the places beside it), the place cards on the right. On a phone
          this stacks — map first, then the cards.
        */}
        <div class="md:grid md:grid-cols-2 md:items-start md:gap-6">
          <div class="mb-6 md:sticky md:top-4 md:mb-0">
            <DestinationMap destinationId={dest.id} pois={pois} paths={paths} />
          </div>

          <div>
            {places.map(({ place, PlaceBody, placeSources, journeys }) => (
              <Card
                cardId={place.id}
                title={place.data.name}
                image={place.data.image}
                sourceEntries={placeSources}
              >
                <PlaceBody />
                <Journeys journeys={journeys} />
              </Card>
            ))}
          </div>
        </div>
      </DestinationTab>
    ))
  }

  <script>
    // Swap which destination panel is visible. Pure DOM toggling — no framework,
    // so it works the instant the HTML lands even before anything else loads.
    const tabs = [...document.querySelectorAll<HTMLButtonElement>('[data-tab]')];
    const panels = [...document.querySelectorAll<HTMLElement>('[data-tab-panel]')];

    for (const tab of tabs) {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab;
        for (const t of tabs) t.setAttribute('aria-selected', String(t === tab));
        for (const p of panels) p.hidden = p.dataset.tabPanel !== id;
      });
    }
  </script>
</Base>
