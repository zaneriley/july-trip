---
import Base from '../layouts/Base.astro';
import DestinationMap from '../components/DestinationMap.astro';
import { CATEGORY_META } from '../lib/categories';
import { comparisonColumns } from '../lib/compare';
import { getCollection } from 'astro:content';

// Home is everything in one place: a single map carrying both cities' points, and
// the places we're looking at as a grid of real photos. The deciding happens in
// the group thread — this is the shared board it points at.
const pois = await getCollection('pois');
const paths = await getCollection('paths');
const photos = await getCollection('photos');
const columns = await comparisonColumns();

// Group photos by the subject (place/poi/route) they depict.
const photosBySubject = new Map<string, typeof photos>();
for (const photo of photos) {
  const list = photosBySubject.get(photo.data.subject) ?? [];
  list.push(photo);
  photosBySubject.set(photo.data.subject, list);
}

// A couple of photo subjects aren't map points (the route as a whole); name them
// here so every tile resolves. Everything else is looked up from its poi.
const extraSubjects: Record<string, { name: string; category: string; destination: string; sourceUrl: string }> = {
  'alpine-route': {
    name: 'Tateyama Kurobe alpine route',
    category: 'sightseeing',
    destination: 'kurobe',
    sourceUrl: 'https://www.alpen-route.com/en/',
  },
};

// Build one tile per subject that has photos, ordered Kurobe first then Atami.
const destOrder: Record<string, number> = { kurobe: 0, atami: 1 };
const tiles = [...photosBySubject.keys()]
  .map((subject) => {
    const poi = pois.find((p) => p.id === subject);
    const meta = poi
      ? {
          name: poi.data.name,
          category: poi.data.category,
          destination: poi.data.destination.id,
          sourceUrl: poi.data.source.url,
        }
      : extraSubjects[subject];
    if (!meta) return null;
    return { subject, ...meta, photo: photosBySubject.get(subject)![0] };
  })
  .filter((t): t is NonNullable<typeof t> => t !== null)
  .sort((a, b) => (destOrder[a.destination] ?? 9) - (destOrder[b.destination] ?? 9));

// Places to eat, from the Japanese food research — split by town.
const food = pois.filter((p) => p.data.category === 'food');
const foodColumns = [
  { title: 'Kurobe', items: food.filter((f) => f.data.destination.id === 'kurobe') },
  { title: 'Atami', items: food.filter((f) => f.data.destination.id === 'atami') },
];

// Decision facts for these dates — sourced, ordered.
const notes = (await getCollection('notes')).sort((a, b) => a.data.order - b.data.order);
const noteTag: Record<string, string> = { both: 'Both', kurobe: 'Kurobe', atami: 'Atami' };
---

<Base
  title="Kurobe or Atami? — July 3 to 5"
  description="Both options on one map, with photos of every place: the alpine route at Kurobe, or onsen by the sea at Atami. We'll sort it out in the chat."
  ogImage="/og/home.png"
  wide={true}
>
  <header class="mb-5">
    <h1 class="m-0 text-2xl font-semibold text-stone-900">Where should we go, July 3 to 5?</h1>
    <p class="mt-2 text-[15px] leading-relaxed text-stone-600">
      Both options on one map. {' '}
      {
        columns.map((c, i) => (
          <>
            {i > 0 && ' · '}
            <a href={`/${c.dest.id}`} class="text-stone-800 underline decoration-stone-300 underline-offset-2 hover:text-stone-900">
              {c.dest.data.name}
            </a>
            {c.time && <> {c.time} from Shibuya</>}
          </>
        ))
      }.
    </p>
  </header>

  <!-- One giant map carrying every point from both cities. -->
  <DestinationMap destinationId="all" pois={pois} paths={paths} />

  <!-- The places, as a grid of real photos. Names and sources only — no invented copy. -->
  <h2 class="mt-8 mb-3 text-lg font-semibold text-stone-900">The places</h2>
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
    {
      tiles.map((tile) => (
        <div class="flex flex-col overflow-hidden rounded-xl border border-stone-200 bg-white transition hover:border-stone-400">
          <a href={`/${tile.destination}`} class="block">
            <img
              src={tile.photo.data.src}
              alt={tile.photo.data.alt}
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
            />
            <div class="px-3 pt-2.5">
              <div class="flex items-center gap-1.5">
                <span
                  class="inline-block h-2 w-2 shrink-0 rounded-full"
                  style={`background:${CATEGORY_META[tile.category]?.color ?? '#888'}`}
                />
                <span class="text-xs text-stone-400">{tile.destination === 'kurobe' ? 'Kurobe' : 'Atami'}</span>
              </div>
              <h3 class="m-0 mt-1 text-[15px] font-medium leading-snug text-stone-900">{tile.name}</h3>
            </div>
          </a>
          <a
            href={tile.photo.data.creditUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto px-3 pb-2.5 pt-2 text-[11px] text-stone-400 hover:text-stone-600"
          >
            {tile.photo.data.credit}
          </a>
        </div>
      ))
    }
  </div>

  <!-- Where to eat. The names link to the source; the notes and ratings are theirs. -->
  <h2 class="mt-8 mb-3 text-lg font-semibold text-stone-900">Where to eat</h2>
  <div class="grid gap-4 md:grid-cols-2">
    {
      foodColumns.map((col) => (
        <div class="rounded-2xl border border-stone-200 bg-white p-4">
          <h3 class="m-0 text-[15px] font-semibold text-stone-900">{col.title}</h3>
          <ul class="m-0 mt-3 list-none space-y-3 p-0">
            {col.items.map((f) => (
              <li>
                <a
                  href={f.data.source.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[15px] font-medium text-stone-900 underline decoration-stone-300 underline-offset-2 hover:text-stone-950"
                >
                  {f.data.name}
                </a>
                <p class="m-0 mt-0.5 text-[13px] leading-snug text-stone-600">{f.data.note}</p>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <!-- Sourced facts that bear on the dates — not editorial; each links its source. -->
  <h2 class="mt-8 mb-3 text-lg font-semibold text-stone-900">Good to know for July 3 to 5</h2>
  <div class="overflow-hidden rounded-2xl border border-stone-200 bg-white">
    {
      notes.map((n, i) => (
        <div class={`px-4 py-3 ${i > 0 ? 'border-t border-stone-100' : ''}`}>
          <p class="m-0 text-[14px] leading-relaxed text-stone-700">
            <span class="mr-1.5 text-xs text-stone-400">{noteTag[n.data.destination]}</span>
            {n.data.text}{' '}
            <a
              href={n.data.source.url}
              target="_blank"
              rel="noopener noreferrer"
              class="whitespace-nowrap text-stone-500 underline decoration-stone-300 underline-offset-2 hover:text-stone-800"
            >
              — {n.data.source.label}
            </a>
          </p>
        </div>
      ))
    }
  </div>
</Base>
