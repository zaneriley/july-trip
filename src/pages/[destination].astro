---
import Base from '../layouts/Base.astro';
import DestinationMap from '../components/DestinationMap.astro';
import { formatDuration, formatYen } from '../lib/format';
import { getCollection } from 'astro:content';

// The "explore this option" page: a stack of small collections with a sticky
// section nav, a one-tap switch to the other city, and the walkability / seat /
// caveat metadata surfaced (not buried in prose). See ADR 0008.
export async function getStaticPaths() {
  const destinations = await getCollection('destinations');
  return destinations.map((dest) => ({ params: { destination: dest.id } }));
}

const destinations = await getCollection('destinations');
const { destination: destId } = Astro.params;
const dest = destinations.find((d) => d.id === destId)!;
const other = destinations.find((d) => d.id !== destId)!;
const dates = 'July 3–5 (Fri–Sun)';

const pois = (await getCollection('pois')).filter((p) => p.data.destination.id === destId);
const paths = (await getCollection('paths')).filter((p) => p.data.destination.id === destId);
const poiById = new Map(pois.map((p) => [p.id, p]));

const places = await getCollection('places');
const placeToDest = new Map(places.map((p) => [p.id, p.data.destination.id]));
const journeys = (await getCollection('journeys')).filter((j) => placeToDest.get(j.data.to.id) === destId);

const photos = await getCollection('photos');
const photoBySubject = new Map<string, (typeof photos)[number]>();
const photosBySubject = new Map<string, (typeof photos)[number][]>();
for (const photo of photos) {
  if (!photoBySubject.has(photo.data.subject)) photoBySubject.set(photo.data.subject, photo);
  const list = photosBySubject.get(photo.data.subject) ?? [];
  list.push(photo);
  photosBySubject.set(photo.data.subject, list);
}

const seeCategories = ['sightseeing', 'viewpoint', 'onsen', 'neighborhood'];
const sightSubjects = new Set(pois.filter((p) => seeCategories.includes(p.data.category)).map((p) => p.id));
if (destId === 'kurobe') sightSubjects.add('alpine-route');
const gallery = photos.filter((p) => sightSubjects.has(p.data.subject));
const captionFor = (subject: string) =>
  poiById.get(subject)?.data.name ?? (subject === 'alpine-route' ? 'Alpine route' : subject);

const restaurants = pois.filter((p) => p.data.category === 'food').map((p) => ({ poi: p, photo: photoBySubject.get(p.id) }));
const cafes = pois
  .filter((p) => p.data.category === 'coffee' || p.data.category === 'kissaten')
  .map((p) => ({ poi: p, photo: photoBySubject.get(p.id) }));

const kids = (await getCollection('kids')).filter((k) => k.data.destination.id === destId).sort((a, b) => a.data.order - b.data.order);
const weather = (await getCollection('weather')).find((w) => w.data.destination.id === destId);
const goodToKnow = (await getCollection('notes')).filter((n) => n.data.destination === destId).sort((a, b) => a.data.order - b.data.order);
const todo = (await getCollection('todo')).filter((t) => t.data.destination.id === destId).sort((a, b) => a.data.order - b.data.order);
const popculture = (await getCollection('popculture')).filter((p) => p.data.destination.id === destId).sort((a, b) => a.data.order - b.data.order);
const lodging = (await getCollection('lodging')).filter((l) => l.data.destination.id === destId).sort((a, b) => a.data.order - b.data.order);
const neat = (await getCollection('neat')).filter((n) => n.data.destination.id === destId).sort((a, b) => a.data.order - b.data.order);

// The section nav — decision-weight order, only what's present.
const nav = [
  { id: 'map', label: 'Map', show: true },
  { id: 'getting-there', label: 'Getting there', show: journeys.length > 0 },
  { id: 'weather', label: 'Weather', show: !!weather },
  { id: 'stay', label: 'Where to stay', show: lodging.length > 0 },
  { id: 'eat', label: 'Eat', show: restaurants.length > 0 },
  { id: 'kids', label: 'With a 3-yo', show: kids.length > 0 },
  { id: 'cafes', label: 'Cafes', show: cafes.length > 0 },
  { id: 'photos', label: 'Photos', show: gallery.length > 0 },
  { id: 'more', label: 'More to do', show: todo.length > 0 },
  { id: 'culture', label: 'Pop culture', show: popculture.length > 0 },
  { id: 'neat', label: 'Neat stuff', show: neat.length > 0 },
  { id: 'good', label: 'Good to know', show: goodToKnow.length > 0 },
].filter((s) => s.show);

const srcLink = 'whitespace-nowrap text-stone-400 underline decoration-stone-300 underline-offset-2 hover:text-stone-700';
const section = 'mt-8 scroll-mt-20';
// On a phone a card collection is a horizontal swipe-shelf (cards ~78% wide, the
// next peeks) so the section is one card tall and you can see several headers at
// once; at sm+ it reflows to the normal grid. Keeps breadth visible, not spacing.
const shelf =
  '-mx-4 flex snap-x snap-mandatory gap-3 overflow-x-auto px-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden [&>*]:w-[78%] [&>*]:shrink-0 [&>*]:snap-start sm:mx-0 sm:grid sm:gap-3 sm:overflow-visible sm:px-0 sm:[&>*]:w-auto';
// Photos are smaller, so the shelf shows ~2.3 thumbnails at a time.
const shelfPhotos =
  '-mx-4 flex snap-x snap-mandatory gap-2 overflow-x-auto px-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden [&>*]:w-[42%] [&>*]:shrink-0 [&>*]:snap-start sm:mx-0 sm:grid sm:grid-cols-3 sm:gap-2 sm:overflow-visible sm:px-0 sm:[&>*]:w-auto md:grid-cols-4';
// A walkability chip: amber when it needs a train/bus/car, calm when it's a walk.
const accessChip = (a?: string) =>
  a?.includes('needs') ? 'bg-amber-50 text-amber-700' : 'bg-stone-100 text-stone-500';
const chip = 'rounded-full px-2 py-0.5 text-[11px]';
const neutralChip = 'bg-stone-100 text-stone-500';
// The trip is Fri–Sun: amber a closed-day chip when the closure lands on those
// days, emerald when it's open daily, neutral otherwise.
const closedHitsTrip = (d: string) => /Fri|Sat|Sun/.test(d);
const closedChipClass = (d: string) =>
  d === 'none' ? 'bg-emerald-50 text-emerald-700' : closedHitsTrip(d) ? 'bg-amber-50 text-amber-700' : neutralChip;
const closedLabel = (d: string) => (d === 'none' ? 'open daily' : `closed ${d}`);
const locateBtn = 'cursor-pointer border border-stone-300 text-stone-600 hover:border-stone-900 hover:text-stone-900';
---

<Base title={`${dest.data.name} — July 3 to 5`} description={dest.data.tagline} ogImage={`/og/${destId}.png`} wide={true}>
  <header class="mb-4 flex items-start justify-between gap-3">
    <div>
      <a href="/" class="text-sm text-stone-500 hover:text-stone-800">← Kurobe or Atami?</a>
      <h1 class="mt-2 text-2xl font-semibold text-stone-900">{dest.data.name}</h1>
      <p class="mt-1 text-[15px] leading-relaxed text-stone-600">{dest.data.tagline}</p>
      <p class="mt-1 text-[13px] text-stone-400">{dates}</p>
    </div>
    <a
      id="city-toggle"
      href={`/${other.id}`}
      class="shrink-0 rounded-lg border border-stone-300 px-3 py-2 text-sm font-medium text-stone-700 transition hover:border-stone-900 hover:bg-stone-900 hover:text-white"
    >
      {other.data.name} →
    </a>
  </header>

  {/* Sticky section nav — the index over a long page, and a one-glance overview. */}
  <nav
    class="sticky top-0 z-20 -mx-4 mb-6 flex gap-2 overflow-x-auto border-b border-stone-200 bg-stone-50/95 px-4 py-2 backdrop-blur md:-mx-6 md:px-6"
    aria-label="On this page"
  >
    {
      nav.map((s) => (
        <a
          href={`#${s.id}`}
          data-nav={s.id}
          class="whitespace-nowrap rounded-full border border-stone-200 px-3 py-1 text-[13px] text-stone-600 transition hover:border-stone-400 aria-[current=true]:border-stone-900 aria-[current=true]:bg-stone-900 aria-[current=true]:text-white"
        >
          {s.label}
        </a>
      ))
    }
  </nav>

  <section id="map" class="scroll-mt-20">
    <DestinationMap destinationId={dest.id} pois={pois} paths={paths} />
  </section>

  {/* Getting there — with the seat note, changes, and source caveat surfaced. */}
  {
    journeys.length > 0 && (
      <section id="getting-there" class={section}>
        <h2 class="m-0 mb-3 text-lg font-semibold text-stone-900">Getting there from Shibuya</h2>
        <div class={`${shelf} sm:grid-cols-2`}>
          {journeys.map((j) => (
            <div class="rounded-xl border border-stone-200 bg-white px-4 py-3">
              <p class="m-0 text-[15px] font-medium text-stone-900">{j.data.label}</p>
              <p class="m-0 mt-0.5 text-[14px] text-stone-700">
                {j.data.totalDurationMin && formatDuration(j.data.totalDurationMin.value)}
                {j.data.totalFareYen && <> · {formatYen(j.data.totalFareYen.value)}</>}
                {j.data.legs.length > 1 && <> · {j.data.legs.length - 1} {j.data.legs.length - 1 === 1 ? 'change' : 'changes'}</>}
              </p>
              <p class="m-0 mt-1 text-[12px] text-stone-400">{[j.data.from, ...j.data.legs.map((l) => l.to)].join(' → ')}</p>
              {j.data.seatNote && <p class="m-0 mt-2 text-[13px] leading-snug text-stone-600">{j.data.seatNote}</p>}
              {j.data.caveat && <p class="m-0 mt-1 text-[11px] italic leading-snug text-stone-400">{j.data.caveat}</p>}
            </div>
          ))}
        </div>
      </section>
    )
  }

  {/* Weather. */}
  {
    weather && (
      <section id="weather" class={section}>
        <h2 class="m-0 text-lg font-semibold text-stone-900">The weather, {dates}</h2>
        <p class="mt-0.5 text-[14px] text-stone-600">{weather.data.headline}</p>
        <dl class="mt-3 overflow-hidden rounded-2xl border border-stone-200 bg-white">
          {weather.data.rows.map((row, i) => (
            <div class={`grid grid-cols-[7rem_1fr] gap-3 px-4 py-3 ${i > 0 ? 'border-t border-stone-100' : ''}`}>
              <dt class="text-[13px] text-stone-400">{row.label}</dt>
              <dd class="m-0 text-[14px] leading-snug text-stone-700">
                {row.value}{' '}
                {row.sourceUrl && (
                  <a href={row.sourceUrl} target="_blank" rel="noopener noreferrer" class={srcLink}>
                    — {row.sourceLabel}
                  </a>
                )}
              </dd>
            </div>
          ))}
        </dl>
      </section>
    )
  }

  {/* Where to stay — the biggest planning fact, with the facts a family weighs. */}
  {
    lodging.length > 0 && (
      <section id="stay" class={section}>
        <h2 class="m-0 text-lg font-semibold text-stone-900">Where to stay · {lodging.length}</h2>
        <p class="mt-0.5 text-[13px] text-stone-400">Prices are rough per-person estimates with two meals — confirm live for July 3–5.</p>
        <div class="mt-3 grid gap-3 sm:grid-cols-2">
          {lodging.map((l) => {
            const imgs = photosBySubject.get(l.id) ?? [];
            return (
              <div class="overflow-hidden rounded-xl border border-stone-200 bg-white">
                {imgs.length > 0 && (
                  <div class="relative">
                    <div class="flex snap-x snap-mandatory gap-1 overflow-x-auto [-webkit-overflow-scrolling:touch] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
                      {imgs.map((ph) => (
                        <img
                          src={ph.data.src}
                          alt={ph.data.alt}
                          loading="lazy"
                          class={`aspect-[16/9] ${imgs.length > 1 ? 'w-[92%]' : 'w-full'} shrink-0 snap-start object-cover`}
                        />
                      ))}
                    </div>
                    {imgs.length > 1 && (
                      <span class="pointer-events-none absolute right-2 top-2 rounded-full bg-black/55 px-2 py-0.5 text-[11px] font-medium text-white">
                        {imgs.length} photos · swipe
                      </span>
                    )}
                  </div>
                )}
                <div class="px-4 py-3">
                  <div class="flex items-baseline justify-between gap-2">
                    <a href={l.data.source.url} target="_blank" rel="noopener noreferrer" class="text-[15px] font-medium text-stone-900 underline decoration-stone-300 underline-offset-2 hover:text-stone-950">
                      {l.data.name}
                    </a>
                    <span class="shrink-0 rounded-full bg-stone-100 px-2 py-0.5 text-[11px] text-stone-500">{l.data.tier}</span>
                  </div>
                  {l.data.nameJa && <p class="m-0 text-xs text-stone-400">{l.data.nameJa}</p>}
                  <p class="m-0 mt-1.5 text-[14px] font-semibold text-stone-900">{l.data.price}</p>
                  <dl class="m-0 mt-2 grid grid-cols-[5rem_1fr] gap-x-3 gap-y-1.5 text-[13px] leading-snug">
                    <dt class="text-stone-400">getting in</dt>
                    <dd class="m-0 text-stone-700">{l.data.access}</dd>
                    <dt class="text-stone-400">rooms</dt>
                    <dd class="m-0 text-stone-700">{l.data.rooms}</dd>
                    <dt class="text-stone-400">private bath</dt>
                    <dd class="m-0 text-stone-700">{l.data.privateOnsen}</dd>
                    <dt class="text-stone-400">with a kid</dt>
                    <dd class="m-0 text-stone-700">{l.data.kids}</dd>
                  </dl>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  {/* Restaurants — with a walkability chip. */}
  {
    restaurants.length > 0 && (
      <section id="eat" class={section}>
        <h2 class="m-0 mb-3 text-lg font-semibold text-stone-900">Restaurants · {restaurants.length}</h2>
        <div class={`${shelf} sm:grid-cols-2 lg:grid-cols-3`}>
          {restaurants.map(({ poi, photo }) => (
            <div class="overflow-hidden rounded-xl border border-stone-200 bg-white">
              {photo && <img src={photo.data.src} alt={photo.data.alt} loading="lazy" class="aspect-[16/10] w-full object-cover" />}
              <div class="px-3 py-2.5">
                <a href={poi.data.source.url} target="_blank" rel="noopener noreferrer" class="text-[15px] font-medium text-stone-900 underline decoration-stone-300 underline-offset-2 hover:text-stone-950">
                  {poi.data.name}
                </a>
                <div class="mt-1.5 flex flex-wrap gap-1.5">
                  {poi.data.rating && <span class={`${chip} ${neutralChip}`}>★ {poi.data.rating}</span>}
                  {poi.data.priceBand && <span class={`${chip} ${neutralChip}`}>{poi.data.priceBand}</span>}
                  {poi.data.closedDay && <span class={`${chip} ${closedChipClass(poi.data.closedDay)}`}>{closedLabel(poi.data.closedDay)}</span>}
                  {poi.data.reservation && <span class={`${chip} ${neutralChip}`}>{poi.data.reservation}</span>}
                  {poi.data.accessFromStation && <span class={`${chip} ${accessChip(poi.data.accessFromStation)}`}>{poi.data.accessFromStation}</span>}
                  <button type="button" data-locate={poi.id} class={`${chip} ${locateBtn}`}>on the map ↑</button>
                </div>
                <p class="m-0 mt-2 text-[13px] leading-snug text-stone-600">{poi.data.note}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {/* With a three-year-old. */}
  {
    kids.length > 0 && (
      <section id="kids" class={section}>
        <h2 class="m-0 mb-3 text-lg font-semibold text-stone-900">With a three-year-old · {kids.length}</h2>
        <div class={`${shelf} sm:grid-cols-2`}>
          {kids.map((k) => {
            const photo = photoBySubject.get(k.id);
            return (
              <div class={`overflow-hidden rounded-xl border bg-white ${k.data.fit === 'caution' ? 'border-amber-300' : 'border-stone-200'}`}>
                {photo && <img src={photo.data.src} alt={photo.data.alt} loading="lazy" class="aspect-[16/9] w-full object-cover" />}
                <div class="px-4 py-3">
                  <p class="m-0 text-[15px] font-medium text-stone-900">
                    {k.data.fit === 'caution' && <span class="mr-1 text-amber-600">heads up —</span>}
                    {k.data.name}
                  </p>
                  <p class="m-0 mt-0.5 text-[13px] leading-snug text-stone-600">
                    {k.data.note}{' '}
                    <a href={k.data.source.url} target="_blank" rel="noopener noreferrer" class={srcLink}>— {k.data.source.label}</a>
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  {/* Cafes & kissaten — with a walkability chip. */}
  {
    cafes.length > 0 && (
      <section id="cafes" class={section}>
        <h2 class="m-0 mb-3 text-lg font-semibold text-stone-900">Cafes &amp; kissaten · {cafes.length}</h2>
        <div class={`${shelf} sm:grid-cols-2 lg:grid-cols-3`}>
          {cafes.map(({ poi, photo }) => (
            <div class="overflow-hidden rounded-xl border border-stone-200 bg-white">
              {photo && <img src={photo.data.src} alt={photo.data.alt} loading="lazy" class="aspect-[16/10] w-full object-cover" />}
              <div class="px-3 py-2.5">
                <a href={poi.data.source.url} target="_blank" rel="noopener noreferrer" class="text-[15px] font-medium text-stone-900 underline decoration-stone-300 underline-offset-2 hover:text-stone-950">
                  {poi.data.name}
                </a>
                <div class="mt-1.5 flex flex-wrap gap-1.5">
                  {poi.data.accessFromStation && <span class={`${chip} ${accessChip(poi.data.accessFromStation)}`}>{poi.data.accessFromStation}</span>}
                  <button type="button" data-locate={poi.id} class={`${chip} ${locateBtn}`}>on the map ↑</button>
                </div>
                <p class="m-0 mt-2 text-[13px] leading-snug text-stone-600">{poi.data.note}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {/* Photos. */}
  {
    gallery.length > 0 && (
      <section id="photos" class={section}>
        <h2 class="m-0 mb-3 text-lg font-semibold text-stone-900">Photos · {gallery.length}</h2>
        <div class={shelfPhotos}>
          {gallery.map((p) => (
            <figure class="m-0 overflow-hidden rounded-xl border border-stone-200 bg-white">
              <img src={p.data.src} alt={p.data.alt} loading="lazy" class="aspect-[4/3] w-full object-cover" />
              <figcaption class="px-2.5 py-2 text-[13px] font-medium leading-snug text-stone-800">{captionFor(p.data.subject)}</figcaption>
            </figure>
          ))}
        </div>
      </section>
    )
  }

  {/* More to do — with the tag chip. */}
  {
    todo.length > 0 && (
      <section id="more" class={section}>
        <h2 class="m-0 mb-3 text-lg font-semibold text-stone-900">More to do · {todo.length}</h2>
        <div class={`${shelf} sm:grid-cols-2`}>
          {todo.map((t) => {
            const photo = photoBySubject.get(t.id);
            return (
              <div class="overflow-hidden rounded-xl border border-stone-200 bg-white">
                {photo && <img src={photo.data.src} alt={photo.data.alt} loading="lazy" class="aspect-[16/9] w-full object-cover" />}
                <div class="px-4 py-3">
                  <div class="flex items-baseline justify-between gap-2">
                    <p class="m-0 text-[15px] font-medium text-stone-900">{t.data.name}</p>
                    {t.data.tag && <span class="shrink-0 rounded-full bg-stone-100 px-2 py-0.5 text-[11px] text-stone-500">{t.data.tag}</span>}
                  </div>
                  <p class="m-0 mt-0.5 text-[13px] leading-snug text-stone-600">
                    {t.data.note}{' '}
                    <a href={t.data.source.url} target="_blank" rel="noopener noreferrer" class={srcLink}>— {t.data.source.label}</a>
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  {/* You might know it from — pop culture. */}
  {
    popculture.length > 0 && (
      <section id="culture" class={section}>
        <h2 class="m-0 mb-3 text-lg font-semibold text-stone-900">You might know it from</h2>
        <div class={`${shelf} sm:grid-cols-2`}>
          {popculture.map((p) => {
            const photo = photoBySubject.get(p.id);
            return (
            <div class="overflow-hidden rounded-xl border border-stone-200 bg-white">
              {photo && <img src={photo.data.src} alt={photo.data.alt} loading="lazy" class="aspect-[16/9] w-full object-cover" />}
              <div class="px-4 py-3">
              <p class="m-0 text-xs text-stone-400">{p.data.medium}</p>
              <p class="m-0 text-[15px] font-medium leading-snug text-stone-900">{p.data.title}</p>
              <p class="m-0 mt-0.5 text-[13px] leading-snug text-stone-600">
                {p.data.note}{' '}
                <a href={p.data.source.url} target="_blank" rel="noopener noreferrer" class={srcLink}>— {p.data.source.label}</a>
              </p>
              </div>
            </div>
            );
          })}
        </div>
      </section>
    )
  }

  {/* Neat stuff I found — the genuinely offbeat. */}
  {
    neat.length > 0 && (
      <section id="neat" class={section}>
        <h2 class="m-0 mb-3 text-lg font-semibold text-stone-900">Neat stuff I found</h2>
        <div class={`${shelf} sm:grid-cols-2`}>
          {neat.map((n) => {
            const photo = photoBySubject.get(n.id);
            return (
              <div class="overflow-hidden rounded-xl border border-stone-200 bg-white">
                {photo && <img src={photo.data.src} alt={photo.data.alt} loading="lazy" class="aspect-[16/9] w-full object-cover" />}
                <div class="px-4 py-3">
                  <div class="flex items-baseline justify-between gap-2">
                    <p class="m-0 text-[15px] font-medium text-stone-900">{n.data.name}</p>
                    {n.data.flag && <span class="shrink-0 rounded-full bg-amber-50 px-2 py-0.5 text-[11px] text-amber-700">{n.data.flag}</span>}
                  </div>
                  <p class="m-0 mt-0.5 text-[13px] leading-snug text-stone-600">
                    {n.data.note}{' '}
                    <a href={n.data.source.url} target="_blank" rel="noopener noreferrer" class={srcLink}>— {n.data.source.label}</a>
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  {/* Good to know. */}
  {
    goodToKnow.length > 0 && (
      <section id="good" class={section}>
        <h2 class="m-0 mb-3 text-lg font-semibold text-stone-900">Good to know</h2>
        <div class="overflow-hidden rounded-2xl border border-stone-200 bg-white">
          {goodToKnow.map((n, i) => (
            <div class={`px-4 py-3 ${i > 0 ? 'border-t border-stone-100' : ''}`}>
              <p class="m-0 text-[14px] leading-relaxed text-stone-700">
                {n.data.text}{' '}
                <a href={n.data.source.url} target="_blank" rel="noopener noreferrer" class={srcLink}>— {n.data.source.label}</a>
              </p>
            </div>
          ))}
        </div>
      </section>
    )
  }

  <script>
    // Keep the "other city" link pointed at the same section you're reading, so
    // switching cities is a one-tap, place-preserving compare.
    const toggle = document.getElementById('city-toggle') as HTMLAnchorElement | null;
    if (toggle) {
      const base = toggle.getAttribute('href') ?? '/';
      const sync = () => toggle.setAttribute('href', base + location.hash);
      sync();
      addEventListener('hashchange', sync);
    }

    // Highlight the nav chip for the section in view (scroll-spy).
    const chips = new Map(
      [...document.querySelectorAll<HTMLElement>('[data-nav]')].map((c) => [c.dataset.nav, c]),
    );
    const spy = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            for (const c of chips.values()) c.removeAttribute('aria-current');
            chips.get(e.target.id)?.setAttribute('aria-current', 'true');
          }
        }
      },
      { rootMargin: '-20% 0px -70% 0px' },
    );
    for (const id of chips.keys()) {
      const el = id && document.getElementById(id);
      if (el) spy.observe(el);
    }

    // "on the map ↑" on a place card: scroll the map into view and ask it (via the
    // map's own script) to pan to and bounce that pin.
    for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-locate]')) {
      btn.addEventListener('click', () => {
        const id = btn.dataset.locate;
        if (!id) return;
        document.getElementById('map')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        document.dispatchEvent(new CustomEvent('poi-focus', { detail: { id } }));
      });
    }
  </script>
</Base>
