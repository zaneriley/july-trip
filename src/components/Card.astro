---
/*
  A card is a piece of content, not a row of chips. It is a title, some real
  prose, maybe a photo, maybe a price written as a sentence, and a link to where
  the facts came from. That is the whole shape — deliberately there is no slot
  for a category, tag, badge, or label, so none can creep in.

  Price is plain text on purpose: "about ¥12,000 for a twin room" reads like a
  human wrote it, not "¥12,000" stamped in a coloured pill.
*/
interface Props {
  cardId: string;
  title: string;
  /** Where the facts came from. Shown as a small "source" link at the bottom. */
  source?: { label: string; url: string };
  /** A real price stated in words, e.g. "about ¥12,000 per night". */
  price?: string;
  /** One photo: a real image with a credit, never a stock placeholder. */
  image?: { src: string; alt: string; credit?: string };
}

const { cardId, title, source, price, image } = Astro.props;
import Heart from './Heart.astro';
---

<article class="mb-5 overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm">
  {
    image && (
      <figure class="m-0">
        <img src={image.src} alt={image.alt} loading="lazy" class="aspect-[4/3] w-full object-cover" />
        {image.credit && (
          <figcaption class="px-4 pt-2 text-xs text-stone-400">{image.credit}</figcaption>
        )}
      </figure>
    )
  }

  <div class="px-4 py-4">
    <h3 class="m-0 text-lg font-semibold text-stone-900">{title}</h3>

    <!-- The description is authored as real prose between these tags. -->
    <div class="prose-trip mt-2 space-y-2 text-[15px] leading-relaxed text-stone-700">
      <slot />
    </div>

    {price && <p class="mt-3 text-[15px] text-stone-600">{price}</p>}

    <div class="mt-4 flex items-end justify-between gap-3">
      {
        source ? (
          <a
            href={source.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-stone-500 underline decoration-stone-300 underline-offset-2 hover:text-stone-800"
          >
            source: {source.label}
          </a>
        ) : (
          <span></span>
        )
      }
      <Heart cardId={cardId} />
    </div>
  </div>
</article>
