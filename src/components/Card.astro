---
/*
  A card is a piece of content, not a row of chips. It is a title, real prose
  (passed in as the slot), maybe a photo, the provenance for the prose, and a
  heart. There is deliberately no slot for a category, tag, badge, or label, so
  none can creep in (ADR 0001).

  Provenance is first-class: a card takes the resolved source entries behind its
  prose and prints them as plain links at the foot, so any claim can be traced.
*/
import type { CollectionEntry } from 'astro:content';
import Heart from './Heart.astro';
import SourceLinks from './SourceLinks.astro';

interface Props {
  cardId: string;
  title: string;
  // The sources behind this card's prose, already resolved from references.
  sourceEntries?: CollectionEntry<'sources'>[];
  // One photo: a real image with a credit linking back to its source, never a
  // stock placeholder. The credit is the image's provenance (ADR 0003).
  image?: { src: string; alt: string; credit?: string; creditUrl?: string };
}

const { cardId, title, sourceEntries = [], image } = Astro.props;
---

<article class="mb-5 overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm">
  {
    image && (
      <figure class="m-0">
        <img src={image.src} alt={image.alt} loading="lazy" class="aspect-[4/3] w-full object-cover" />
        {image.credit && (
          <figcaption class="px-4 pt-2 text-xs text-stone-400">
            {image.creditUrl ? (
              <a
                href={image.creditUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="underline decoration-stone-300 underline-offset-2 hover:text-stone-600"
              >
                {image.credit}
              </a>
            ) : (
              image.credit
            )}
          </figcaption>
        )}
      </figure>
    )
  }

  <div class="px-4 py-4">
    <h3 class="m-0 text-lg font-semibold text-stone-900">{title}</h3>

    <!-- The description and any journeys are passed in as real prose. -->
    <div class="mt-2 space-y-2 text-[15px] leading-relaxed text-stone-700">
      <slot />
    </div>

    <div class="mt-4 flex items-end justify-between gap-3">
      <div class="min-w-0">
        <SourceLinks entries={sourceEntries} lead="about this place" />
      </div>
      <Heart cardId={cardId} />
    </div>
  </div>
</article>
