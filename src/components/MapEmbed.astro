---
/*
  A map for one place, plus the two links that actually do something useful here.

  Why it's built this way: Google's developer map APIs do not provide transit
  (train) routing for Japan at all — it's a licensing exclusion, not a key or
  signal problem, so a "draw the train route" call always fails. The consumer
  Google Maps app/site DOES have full Japan rail data. So instead of drawing a
  wrong or broken route, we:

    1. show where the place is, with the Maps Embed API (a plain iframe, which
       loads lazily and survives weak signal far better than scripted maps), and
    2. hand the actual routing to Google Maps via a deep link — which opens the
       app on a phone and shows real train directions.

  Both links need no API key, so the route and the coffee search work even before
  a key is set; only the inline map needs the key (and the Maps Embed API enabled).
*/
interface Props {
  // A geocodable location, e.g. "Kurobe Dam, Toyama, Japan".
  query: string;
  // Accessible description of the map.
  label: string;
  // Where directions start from. Defaults to Shibuya Station.
  origin?: string;
}

const { query, label, origin = 'Shibuya Station, Tokyo' } = Astro.props;

const apiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY ?? '';
const hasKey = apiKey.length > 0;

const placeUrl = `https://www.google.com/maps/embed/v1/place?key=${apiKey}&q=${encodeURIComponent(query)}`;

// Deep links into the consumer Google Maps app — the only place Japan transit
// actually works. No API key required.
const directionsUrl =
  `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(origin)}` +
  `&destination=${encodeURIComponent(query)}&travelmode=transit`;
const coffeeUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`coffee near ${query}`)}`;

const linkClass =
  'inline-flex items-center gap-1 rounded-lg border border-stone-300 px-3 py-2 text-sm text-stone-700 transition hover:border-stone-900 hover:text-stone-900';
---

<div class="my-4">
  {
    hasKey ? (
      <iframe
        title={label}
        src={placeUrl}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
        class="aspect-[4/3] w-full rounded-2xl border border-stone-200"
      />
    ) : (
      <div class="flex aspect-[4/3] w-full items-center justify-center rounded-2xl border border-stone-200 bg-stone-100 px-6 text-center text-sm text-stone-500">
        the inline map needs a Google Maps key — the links below work without one
      </div>
    )
  }

  <div class="mt-2 flex flex-wrap gap-2">
    <a href={directionsUrl} target="_blank" rel="noopener noreferrer" class={linkClass}>
      train directions from Shibuya →
    </a>
    <a href={coffeeUrl} target="_blank" rel="noopener noreferrer" class={linkClass}>
      coffee nearby →
    </a>
  </div>
</div>
