---
/*
  A single anonymous reaction. No accounts: the count is shared across everyone
  viewing the page (it lives in the Worker's KV store), and this device remembers
  whether it has already hearted so the same phone can't pad the number.

  Each card passes a stable `cardId`. Tapping toggles: first tap adds a heart,
  second tap takes it back.
*/
interface Props {
  cardId: string;
}

const { cardId } = Astro.props;
---

<button
  type="button"
  data-heart
  data-card-id={cardId}
  aria-pressed="false"
  class="group inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm text-stone-500 transition hover:bg-stone-100 hover:text-rose-600 aria-pressed:text-rose-600"
>
  <!-- The heart fills in once this device has reacted (aria-pressed=true). -->
  <svg
    viewBox="0 0 24 24"
    class="h-5 w-5 fill-none stroke-current stroke-[1.75] group-aria-pressed:fill-current"
    aria-hidden="true"
  >
    <path
      d="M12 20.5l-1.45-1.32C5.4 14.36 2 11.28 2 7.5 2 4.92 4.02 3 6.5 3c1.74 0 3.41.81 4.5 2.09C12.09 3.81 13.76 3 15.5 3 17.98 3 20 4.92 20 7.5c0 3.78-3.4 6.86-8.55 11.68L12 20.5z"
    ></path>
  </svg>
  <span data-heart-count>0</span>
  <span class="sr-only">hearts — tap to react</span>
</button>

<script>
  // This script is bundled once no matter how many Heart components are on the
  // page, so it wires up every button in one pass.

  const API = import.meta.env.PUBLIC_HEART_API_URL?.replace(/\/$/, '') ?? '';
  const STORAGE_KEY = 'july-trip:hearted';

  // The set of card ids this device has already hearted.
  const hearted: Set<string> = new Set(
    JSON.parse(localStorage.getItem(STORAGE_KEY) ?? '[]'),
  );

  function persist() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify([...hearted]));
  }

  const buttons = [...document.querySelectorAll<HTMLButtonElement>('[data-heart]')];

  function render(button: HTMLButtonElement, count: number) {
    const id = button.dataset.cardId!;
    const mine = hearted.has(id);
    button.setAttribute('aria-pressed', String(mine));
    const label = button.querySelector('[data-heart-count]');
    if (label) label.textContent = String(Math.max(0, count));
  }

  // Pull the shared counts once on load. Without a Worker URL the page still
  // works — hearts just stay local to this device until the Worker is deployed.
  async function loadCounts() {
    const counts: Record<string, number> = {};
    if (API) {
      try {
        const res = await fetch(`${API}/hearts`);
        if (res.ok) Object.assign(counts, await res.json());
      } catch {
        // Spotty signal in the mountains is expected; fall back to local state.
      }
    }
    for (const button of buttons) {
      render(button, counts[button.dataset.cardId!] ?? (hearted.has(button.dataset.cardId!) ? 1 : 0));
    }
  }

  for (const button of buttons) {
    button.addEventListener('click', async () => {
      const id = button.dataset.cardId!;
      const label = button.querySelector('[data-heart-count]');
      const current = Number(label?.textContent ?? '0');
      const adding = !hearted.has(id);

      // Update the UI immediately, then tell the Worker. The tap should feel
      // instant even on a slow connection.
      if (adding) hearted.add(id);
      else hearted.delete(id);
      persist();
      render(button, current + (adding ? 1 : -1));

      if (!API) return;
      try {
        await fetch(`${API}/heart/${encodeURIComponent(id)}`, {
          method: adding ? 'POST' : 'DELETE',
        });
      } catch {
        // Keep the optimistic count; it will reconcile on the next page load.
      }
    });
  }

  loadCounts();
</script>
